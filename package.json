{
  "name": "gitactions_proj",
  "version": "1.0.0",
  "description": "This repository is a starter for GitHub Actions automations.",
  "main": "index.js",
  "scripts": {
    "test": "npm run cy:run:chrome",
    "cy:open": "cypress open",
    "cy:run": "cypress run --headless --browser electron",
    "cy:run:chrome": "cypress run --headless --browser chrome",
    "cy:run:firefox": "cypress run --headless --browser firefox",
    "cy:api": "cypress run --headless --browser electron --spec cypress/e2e/api/contracts.cy.ts",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:clean": "node -e \"const fs=require('fs'); ['allure-results','allure-report'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}));\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ajv": "^8.18.0",
    "allure-commandline": "^2.38.1",
    "allure-cypress": "^3.7.1",
    "cypress": "^15.14.0",
    "cypress-axe": "^1.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
